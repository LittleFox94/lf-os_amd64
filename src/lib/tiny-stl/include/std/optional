// vim: ft=cpp
#pragma once

#if defined(NAMESPACE_FOR_TESTING)
#  define _OPTIONAL_NAMESPACE tinystl_std
#  undef  NAMESPACE_FOR_TESTING
#else
#  define _OPTIONAL_NAMESPACE std
#endif

#include <type_traits>

namespace _OPTIONAL_NAMESPACE {
    template<class T>
    class optional {
        public:
            typedef T value_type;

            constexpr optional() noexcept : _storage(false), _has_value(false) { }

            template<class U = std::remove_cv_t<T>>
            constexpr optional(U&& value)
                : _storage(value), _has_value(true) { }

            constexpr ~optional() {
                if(_has_value) {
                    _storage.value.~T();
                }
            }

            constexpr explicit operator bool() const noexcept {
                return _has_value;
            }

            constexpr const T& value() const & {
                return _storage.value;
            }

            constexpr const T* operator->() const noexcept {
                if(!_has_value) { return nullptr; }
                return &_storage.value;
            }

        private:
            union storage {
                T value;
                bool dummy;

                storage(T val) : value(val) { }
                storage(bool x) : dummy(x) { }
                ~storage() {}
            };

            storage _storage;
            bool _has_value;
    };
}

#undef _OPTIONAL_NAMESPACE
